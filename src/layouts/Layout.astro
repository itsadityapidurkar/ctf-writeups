---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="bg-black">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  
  <!-- SEO Tags -->
  <meta name="description" content="A premium collection of CTF challenge writeups, tutorials, and cyber-security insights." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <style is:global>
    :root {
      --neon-green: #39ff14;
      --neon-green-glow: rgba(57, 255, 20, 0.4);
    }
    
    body {
      font-family: 'Outfit', sans-serif;
      background-color: #050505;
      background-image: 
        radial-gradient(at 0% 0%, rgba(20, 50, 20, 0.15) 0px, transparent 50%),
        radial-gradient(at 100% 100%, rgba(20, 40, 20, 0.1) 0px, transparent 50%);
    }

    .font-mono {
      font-family: 'Fira Code', monospace;
    }

    .neon-border {
      border: 1px solid rgba(57, 255, 20, 0.2);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .neon-border:hover {
      border-color: var(--neon-green);
      box-shadow: 0 0 15px var(--neon-green-glow);
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }
    ::-webkit-scrollbar-track {
      background: #0d0d0d;
    }
    ::-webkit-scrollbar-thumb {
      background: #222;
      border-radius: 4px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: var(--neon-green);
    }
  </style>
</head>
<body class="text-gray-200 min-h-screen flex flex-col font-sans antialiased selection:bg-green-500/30 selection:text-green-300">
  
  <!-- Header -->
  <header class="w-full border-b border-green-500/20 bg-black/60 backdrop-blur-md sticky top-0 z-50 transition-all duration-300">
    <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col sm:flex-row justify-between items-center gap-4">
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-8 h-8 rounded bg-green-500/10 border border-green-500/30 flex items-center justify-center font-mono text-green-400 font-bold group-hover:border-green-400 group-hover:shadow-[0_0_10px_rgba(57,255,20,0.3)] transition-all">
          &gt;_
        </div>
        <span class="text-2xl font-bold font-mono text-green-400 tracking-wider group-hover:text-green-300 transition-colors">
          CTF Writeups
        </span>
      </a>
      <nav class="flex items-center gap-6">
        <a href="/" class="text-sm font-medium hover:text-green-400 transition-colors">CTFs</a>
        <a href="/admin" class="text-sm px-3 py-1.5 rounded border border-green-500/30 text-green-400 font-mono hover:bg-green-500/10 hover:border-green-400 transition-all">
          Admin Portal
        </a>
      </nav>
    </div>
  </header>

  <!-- Main Grid -->
  <main class="flex-grow max-w-6xl w-full mx-auto px-6 py-8">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="w-full py-8 border-t border-green-500/10 bg-black/40 text-center text-sm text-gray-500 font-mono">
    <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p>© {new Date().getFullYear()} Aditya Pidurkar</p>
      <div class="flex gap-4">
        <a href="https://github.com/itsadityapidurkar/ctf-writeups" target="_blank" class="hover:text-green-400 transition-colors">GitHub Repository</a>
      </div>
    </div>
  </footer>

</body>
</html>
