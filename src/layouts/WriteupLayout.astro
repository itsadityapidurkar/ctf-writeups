---
import Layout from './Layout.astro';

interface Props {
  title: string;
  ctfName: string;
  category: string;
  difficulty?: string;
  flag?: string;
  banner?: string;
}

const { title, ctfName, category, difficulty, flag, banner } = Astro.props;
---

<Layout title={`${title} | ${ctfName} Writeup`}>
  <div class="max-w-4xl mx-auto">
    <!-- Back Navigation -->
    <div class="mb-6 flex justify-between items-center">
      <a href={`/ctf/${ctfName.toLowerCase().replace(/\s+/g, '-')}`} class="inline-flex items-center gap-2 text-green-400 hover:text-green-300 font-mono text-sm group">
        <span class="transform group-hover:-translate-x-1 transition-transform">&lt;--</span> Back to {ctfName}
      </a>
    </div>

    <!-- Banner -->
    <div class="w-full h-48 sm:h-64 rounded-2xl overflow-hidden border border-green-500/20 mb-8 relative bg-gray-950">
      <img 
        src={banner ? `/assets/${banner}` : '/assets/placeholder.png'} 
        alt={title} 
        class="w-full h-full object-cover opacity-70"
        onerror="this.src='/assets/placeholder.png'"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-transparent to-transparent"></div>
      
      <!-- Challenge Header Metadata -->
      <div class="absolute bottom-6 left-6 right-6">
        <span class="px-2.5 py-1 text-xs font-semibold rounded bg-green-500/10 text-green-400 border border-green-500/30 uppercase font-mono">
          {category}
        </span>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-white mt-3 tracking-tight">
          {title}
        </h1>
      </div>
    </div>

    <!-- Metadata Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8 bg-black/40 border border-green-500/10 p-5 rounded-2xl">
      <div>
        <span class="text-gray-500 text-xs font-mono block">CTF EVENT</span>
        <span class="text-gray-300 font-semibold">{ctfName}</span>
      </div>
      <div>
        <span class="text-gray-500 text-xs font-mono block">DIFFICULTY</span>
        <span class={`font-mono font-bold ${
          difficulty?.toLowerCase() === 'easy' ? 'text-green-400' :
          difficulty?.toLowerCase() === 'medium' ? 'text-yellow-400' :
          difficulty?.toLowerCase() === 'hard' ? 'text-red-400' : 'text-gray-400'
        }`}>{difficulty || 'Unrated'}</span>
      </div>
      <div>
        <span class="text-gray-500 text-xs font-mono block">CATEGORY</span>
        <span class="text-gray-300 font-semibold">{category}</span>
      </div>
    </div>

    <!-- Flag Section (if flag is present) -->
    {flag && (
      <div class="mb-8 p-4 bg-green-500/5 border border-green-500/20 rounded-xl flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
        <div>
          <span class="text-green-400/70 text-xs font-mono block uppercase tracking-widest font-bold">Captured Flag</span>
          <code class="text-green-300 font-mono text-base break-all">{flag}</code>
        </div>
        <button 
          id="copy-flag-btn" 
          data-flag={flag}
          class="px-3 py-1.5 rounded bg-green-500/10 border border-green-500/30 text-xs text-green-400 font-mono hover:bg-green-500/20 hover:border-green-400 active:scale-95 transition-all self-stretch sm:self-auto text-center"
        >
          Copy Flag
        </button>
      </div>
    )}

    <!-- Writeup Content -->
    <article class="markdown-content prose prose-invert max-w-none">
      <slot />
    </article>
  </div>
</Layout>

<script>
  const copyBtn = document.getElementById('copy-flag-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      const flag = copyBtn.dataset.flag;
      if (flag) {
        try {
          await navigator.clipboard.writeText(flag);
          copyBtn.textContent = 'Copied!';
          copyBtn.classList.remove('border-green-500/30', 'text-green-400');
          copyBtn.classList.add('border-green-400', 'text-white', 'bg-green-500/30');
          setTimeout(() => {
            copyBtn.textContent = 'Copy Flag';
            copyBtn.classList.add('border-green-500/30', 'text-green-400');
            copyBtn.classList.remove('border-green-400', 'text-white', 'bg-green-500/30');
          }, 2000);
        } catch (err) {
          console.error('Failed to copy text: ', err);
        }
      }
    });
  }
</script>

<style is:global>
  /* Markdown Typography & Element Styles */
  .markdown-content {
    font-size: 1.05rem;
    line-height: 1.75;
    color: #cbd5e1; /* text-slate-300 */
  }
  
  .markdown-content h1, 
  .markdown-content h2, 
  .markdown-content h3, 
  .markdown-content h4 {
    color: #ffffff;
    font-weight: 700;
    margin-top: 1.75em;
    margin-bottom: 0.5em;
    font-family: 'Fira Code', monospace;
  }

  .markdown-content h1 { font-size: 2rem; border-b: 1px solid rgba(57, 255, 20, 0.1); padding-bottom: 0.3em; }
  .markdown-content h2 { font-size: 1.5rem; color: #39ff14; }
  .markdown-content h3 { font-size: 1.25rem; color: #a3e635; } /* lime-400 */

  .markdown-content p {
    margin-top: 0;
    margin-bottom: 1.25em;
  }

  .markdown-content hr {
    border: 0;
    border-top: 1px solid rgba(57, 255, 20, 0.15);
    margin: 2em 0;
  }

  /* Lists */
  .markdown-content ul {
    list-style-type: disc;
    padding-left: 1.5em;
    margin-bottom: 1.25em;
  }
  .markdown-content ol {
    list-style-type: decimal;
    padding-left: 1.5em;
    margin-bottom: 1.25em;
  }
  .markdown-content li {
    margin-bottom: 0.5em;
  }

  /* Strong/Em */
  .markdown-content strong {
    color: #fff;
    font-weight: 600;
  }

  /* Code & Syntax Highlighting */
  .markdown-content code {
    font-family: 'Fira Code', monospace;
    font-size: 0.9em;
    background: #121212;
    color: #a3e635; /* lime-400 */
    padding: 0.2em 0.4em;
    border-radius: 0.25rem;
    border: 1px solid rgba(255,255,255,0.05);
  }

  .markdown-content pre {
    background: #090909 !important;
    border: 1px solid rgba(57, 255, 20, 0.1);
    border-radius: 0.75rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5em;
    font-family: 'Fira Code', monospace;
  }

  .markdown-content pre code {
    background: transparent;
    border: 0;
    padding: 0;
    font-size: 0.925em;
    color: #cbd5e1;
  }

  /* Blockquotes */
  .markdown-content blockquote {
    border-left: 4px solid var(--neon-green);
    padding-left: 1.25rem;
    color: #94a3b8; /* text-slate-400 */
    font-style: italic;
    margin: 1.5em 0;
    background: rgba(57, 255, 20, 0.02);
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    border-radius: 0 0.5rem 0.5rem 0;
  }

  /* Tables */
  .markdown-content table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5em;
    font-size: 0.95em;
    font-family: 'Fira Code', monospace;
  }
  
  .markdown-content th {
    background: #111;
    color: var(--neon-green);
    font-weight: 600;
    border: 1px solid #222;
    padding: 0.75rem;
    text-align: left;
  }

  .markdown-content td {
    border: 1px solid #222;
    padding: 0.75rem;
  }

  .markdown-content tr:nth-child(even) {
    background: #0b0b0b;
  }

  /* Links */
  .markdown-content a {
    color: var(--neon-green);
    text-decoration: underline;
    transition: color 0.2s;
  }
  .markdown-content a:hover {
    color: #a3e635;
  }
</style>
