---
import Layout from './Layout.astro';

interface Props {
  title: string;
  ctfName: string;
  category: string;
  difficulty?: string;
  flag?: string;
  banner?: string;
}

const { title, ctfName, category, difficulty, flag, banner } = Astro.props;
---

<Layout title={`${title} | ${ctfName} Writeup`}>
  <div class="max-w-4xl mx-auto">
    <!-- Back Navigation -->
    <div class="mb-6 flex justify-between items-center">
      <a href={`/ctf/${ctfName.toLowerCase().replace(/\s+/g, '-')}`} class="inline-flex items-center gap-2 text-cyan-400 hover:text-cyan-300 font-mono text-sm group transition-colors">
        <span class="transform group-hover:-translate-x-1 transition-transform duration-300">&lt;--</span> Back to {ctfName}
      </a>
    </div>

    <!-- Banner -->
    <div class="w-full h-48 sm:h-64 rounded-3xl overflow-hidden border border-white/5 mb-8 relative bg-zinc-950 flex items-center justify-center">
      <!-- Fallback dynamic gradient overlays -->
      <div class="absolute inset-0 bg-gradient-to-tr from-zinc-950 via-zinc-900 to-zinc-950"></div>
      {ctfName.toLowerCase().includes('pico') && (
        <div class="absolute inset-0 bg-gradient-to-tr from-violet-950 via-indigo-900 to-zinc-950 opacity-90"></div>
      )}
      {ctfName.toLowerCase().includes('imaginary') && (
        <div class="absolute inset-0 bg-gradient-to-tr from-emerald-950 via-teal-900 to-zinc-950 opacity-90"></div>
      )}
      
      {banner && banner !== 'placeholder.png' && !banner.includes('placeholder') && (
        <img 
          src={`/assets/${banner}`} 
          alt={title} 
          class="absolute inset-0 w-full h-full object-cover opacity-25"
          onerror="this.style.display='none'"
        />
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-[#07070a] via-zinc-950/40 to-transparent"></div>
      
      <!-- Challenge Header Metadata -->
      <div class="absolute bottom-6 left-6 right-6 z-10">
        <span class="px-2.5 py-1 text-[10px] font-bold font-mono tracking-widest rounded bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 uppercase">
          {category}
        </span>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-white mt-3 tracking-tight font-outfit">
          {title}
        </h1>
      </div>
    </div>

    <!-- Metadata Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8 bg-zinc-950/40 border border-white/5 p-5 rounded-2xl backdrop-blur-md">
      <div>
        <span class="text-zinc-500 text-[10px] font-mono tracking-widest block mb-1">CTF EVENT</span>
        <span class="text-white font-semibold font-outfit">{ctfName}</span>
      </div>
      <div>
        <span class="text-zinc-500 text-[10px] font-mono tracking-widest block mb-1">DIFFICULTY</span>
        <span class={`font-mono font-bold uppercase text-sm ${
          difficulty?.toLowerCase() === 'easy' ? 'text-emerald-400' :
          difficulty?.toLowerCase() === 'medium' ? 'text-amber-400' :
          difficulty?.toLowerCase() === 'hard' ? 'text-rose-400' : 'text-zinc-400'
        }`}>{difficulty || 'Unrated'}</span>
      </div>
      <div>
        <span class="text-zinc-500 text-[10px] font-mono tracking-widest block mb-1">CATEGORY</span>
        <span class="text-white font-semibold font-outfit">{category}</span>
      </div>
    </div>

    <!-- Flag Section (if flag is present) -->
    {flag && (
      <div class="mb-8 p-5 bg-emerald-500/[0.02] border border-emerald-500/20 rounded-2xl flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 shadow-[0_0_20px_rgba(16,185,129,0.02)]">
        <div class="space-y-1.5 flex-grow">
          <span class="text-emerald-400 text-[10px] font-mono tracking-widest block uppercase font-bold">Captured Flag</span>
          <code class="text-white font-mono text-sm break-all bg-emerald-950/15 border border-emerald-500/10 px-3 py-1.5 rounded-lg block sm:inline-block">{flag}</code>
        </div>
        <button 
          id="copy-flag-btn" 
          data-flag={flag}
          class="px-4 py-2 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-xs text-emerald-400 font-mono hover:bg-emerald-500/20 hover:border-emerald-400 active:scale-95 transition-all duration-300 self-stretch sm:self-auto text-center font-bold"
        >
          Copy Flag
        </button>
      </div>
    )}

    <!-- Writeup Content -->
    <article class="markdown-content prose prose-invert max-w-none">
      <slot />
    </article>
  </div>
</Layout>

<script>
  const copyBtn = document.getElementById('copy-flag-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      const flag = copyBtn.dataset.flag;
      if (flag) {
        try {
          await navigator.clipboard.writeText(flag);
          copyBtn.textContent = 'Copied!';
          copyBtn.classList.remove('border-emerald-500/20', 'text-emerald-400');
          copyBtn.classList.add('border-emerald-400', 'text-white', 'bg-emerald-500/30');
          setTimeout(() => {
            copyBtn.textContent = 'Copy Flag';
            copyBtn.classList.add('border-emerald-500/20', 'text-emerald-400');
            copyBtn.classList.remove('border-emerald-400', 'text-white', 'bg-emerald-500/30');
          }, 2000);
        } catch (err) {
          console.error('Failed to copy text: ', err);
        }
      }
    });
  }
</script>

<style is:global>
  /* Markdown Typography & Element Styles */
  .markdown-content {
    font-size: 1rem;
    line-height: 1.8;
    color: #a1a1aa; /* text-zinc-400 */
  }
  
  .markdown-content h1, 
  .markdown-content h2, 
  .markdown-content h3, 
  .markdown-content h4 {
    color: #ffffff;
    font-weight: 700;
    margin-top: 2em;
    margin-bottom: 0.6em;
    font-family: 'Outfit', sans-serif;
  }

  .markdown-content h1 { font-size: 1.75rem; border-b: 1px solid rgba(255, 255, 255, 0.05); padding-bottom: 0.3em; }
  .markdown-content h2 { font-size: 1.4rem; color: #f4f4f5; border-left: 2px solid var(--accent-cyan); padding-left: 0.5em; }
  .markdown-content h3 { font-size: 1.2rem; color: #e4e4e7; }

  .markdown-content p {
    margin-top: 0;
    margin-bottom: 1.5em;
  }

  .markdown-content hr {
    border: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    margin: 2.5em 0;
  }

  /* Lists */
  .markdown-content ul {
    list-style-type: disc;
    padding-left: 1.5em;
    margin-bottom: 1.5em;
  }
  .markdown-content ol {
    list-style-type: decimal;
    padding-left: 1.5em;
    margin-bottom: 1.5em;
  }
  .markdown-content li {
    margin-bottom: 0.5em;
  }

  /* Strong/Em */
  .markdown-content strong {
    color: #fff;
    font-weight: 600;
  }

  /* Code & Syntax Highlighting */
  .markdown-content code {
    font-family: 'Fira Code', monospace;
    font-size: 0.875em;
    background: #0f0f15;
    color: #38bdf8; /* light-blue-400 */
    padding: 0.2rem 0.4rem;
    border-radius: 0.375rem;
    border: 1px solid rgba(255,255,255,0.03);
  }

  .markdown-content pre {
    background: #09090d !important;
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 1rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.75em;
    font-family: 'Fira Code', monospace;
  }

  .markdown-content pre code {
    background: transparent;
    border: 0;
    padding: 0;
    font-size: 0.9em;
    color: #e4e4e7;
  }

  /* Blockquotes */
  .markdown-content blockquote {
    border-left: 3px solid var(--accent-cyan);
    background: rgba(6, 182, 212, 0.02);
    padding: 1rem 1.25rem;
    border-radius: 0 0.75rem 0.75rem 0;
    margin: 1.5em 0;
    color: #d4d4d8;
  }
  .markdown-content blockquote p {
    margin-bottom: 0;
  }

  /* Tables */
  .markdown-content table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.75em;
    font-size: 0.95rem;
  }
  .markdown-content th {
    background: rgba(255, 255, 255, 0.02);
    color: #fff;
    font-weight: 600;
    text-align: left;
    border-bottom: 2px solid rgba(255,255,255,0.05);
    padding: 0.75rem 1rem;
  }
  .markdown-content td {
    border-bottom: 1px solid rgba(255,255,255,0.03);
    padding: 0.75rem 1rem;
    color: #d4d4d8;
  }
  .markdown-content tr:hover td {
    background: rgba(255, 255, 255, 0.01);
  }

  /* Links */
  .markdown-content a {
    color: #38bdf8;
    text-decoration: underline;
    transition: color 0.2s;
  }
  .markdown-content a:hover {
    color: #7dd3fc;
  }
</style>
