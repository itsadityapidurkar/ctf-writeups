---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import ctfsData from '../data/ctfs.json';

// Fetch all writeups from content collections
const allWriteups = await getCollection('writeups');

// Process and count writeups for each CTF
const ctfs = ctfsData.map(ctf => {
  const ctfWriteups = allWriteups.filter(w => {
    // Resolve CTF ID from frontmatter or the first directory in the slug
    const resolvedCtfId = w.data.ctfId || w.slug.split('/')[0].toLowerCase();
    return resolvedCtfId === ctf.id;
  });

  // Unique categories count
  const categoriesSet = new Set();
  const challengesList: any[] = [];

  ctfWriteups.forEach(w => {
    const rawCategory = w.data.category || w.slug.split('/')[1] || 'Uncategorized';
    // Format category name for consistency
    const category = rawCategory.trim();
    categoriesSet.add(category);
    
    // Resolve Title
    const title = w.data.title || w.slug.split('/').pop()?.replace(/-/g, ' ') || 'Untitled';
    
    // Generate route path
    const categorySlug = category.toLowerCase().replace(/\s+/g, '-');
    const challengeSlug = w.slug.split('/').pop();
    const path = `/ctf/${ctf.id}/${categorySlug}/${challengeSlug}`;
    
    challengesList.push({ title, path });
  });

  return {
    ...ctf,
    writeupCount: ctfWriteups.length,
    categoryCount: categoriesSet.size,
    challenges: challengesList
  };
});

// Format search dataset for the client-side Lunr script
const searchData = ctfs.map(c => ({
  id: c.id,
  name: c.name,
  status: c.status,
  banner: c.banner,
  writeupCount: c.writeupCount,
  categoryCount: c.categoryCount,
  challenges: c.challenges
}));
---

<Layout title="CTF Writeups Archive">
  <div class="space-y-8">
    
    <!-- Hero / Intro -->
    <div class="border border-green-500/10 bg-green-500/[0.01] p-6 sm:p-8 rounded-2xl text-center sm:text-left space-y-4">
      <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
        Security Writeups & Exploit Analysis
      </h2>
      <p class="max-w-2xl text-gray-400 text-base sm:text-lg">
        An archive of solved challenges, binary exploits, cryptographic solutions, and walk-throughs for various Capture The Flag competitions.
      </p>
    </div>

    <!-- Controls: Search & Sort -->
    <div class="flex flex-col md:flex-row justify-between items-stretch md:items-center gap-4 bg-zinc-950/80 p-4 border border-zinc-900 rounded-2xl sticky top-20 z-40 backdrop-blur-md">
      <div class="relative flex-grow max-w-lg">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-zinc-500 font-mono">
          &gt;
        </div>
        <input 
          id="search" 
          type="text" 
          placeholder="Search writeups or challenges... (Press '/' to focus)" 
          class="block w-full pl-8 pr-4 py-2.5 rounded-xl bg-zinc-900/60 text-green-300 placeholder-zinc-500 border border-zinc-800 focus:outline-none focus:border-green-500 focus:ring-1 focus:ring-green-500 font-mono text-sm"
        />
      </div>
      <div class="flex items-center gap-3">
        <span class="text-xs font-mono text-zinc-500 hidden sm:inline">SORT_BY:</span>
        <select id="sort" class="px-4 py-2.5 bg-zinc-900/60 text-green-400 border border-zinc-800 rounded-xl focus:outline-none focus:border-green-500 font-mono text-sm cursor-pointer">
          <option value="az">A–Z Alphabetical</option>
          <option value="za">Z–A Alphabetical</option>
          <option value="writeups">Writeup Count</option>
          <option value="status">Event Status</option>
        </select>
      </div>
    </div>

    <!-- Grid Container -->
    <div id="ctf-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Generated Dynamically by JS -->
    </div>
  </div>
</Layout>

<!-- Load Lunr.js from CDN -->
<script src="https://unpkg.com/lunr/lunr.js" is:inline></script>

<!-- Embedded variables for client-side search -->
<script is:inline define:vars={{ searchData }}></script>

<script is:inline>
  let ctfs = searchData || [];
  let idx = null;
  const grid = document.getElementById("ctf-grid");

  function renderCard(ctf) {
    const card = document.createElement("div");
    card.className = "group relative bg-zinc-950 border border-zinc-800 hover:border-green-500/50 hover:shadow-[0_0_20px_rgba(57,255,20,0.1)] rounded-2xl overflow-hidden transition-all duration-300 cursor-pointer flex flex-col h-full";
    
    // Status Badge Color
    const statusColor = ctf.status === 'active' ? 'bg-green-500' : 'bg-zinc-600';
    
    card.innerHTML = `
      <div class="relative w-full h-44 overflow-hidden bg-zinc-900 border-b border-zinc-800">
        <img 
          src="/assets/${ctf.banner}" 
          alt="${ctf.name}" 
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 opacity-80"
          onerror="this.src='/assets/placeholder.png'"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/80 to-transparent"></div>
        <div class="absolute top-4 right-4 flex items-center gap-2 px-2.5 py-1 rounded bg-black/70 border border-zinc-800 text-xs font-mono">
          <span class="w-1.5 h-1.5 rounded-full ${statusColor}"></span>
          <span class="text-zinc-300 capitalize">${ctf.status}</span>
        </div>
      </div>
      <div class="p-5 flex-grow flex flex-col justify-between">
        <div class="space-y-2">
          <h3 class="text-xl font-bold text-white group-hover:text-green-400 transition-colors">
            ${ctf.name}
          </h3>
          <div class="flex items-center gap-4 text-xs font-mono text-zinc-500">
            <span>${ctf.categoryCount} Categories</span>
            <span>•</span>
            <span>${ctf.writeupCount} Challenges</span>
          </div>
        </div>
        <div class="mt-6 pt-4 border-t border-zinc-900/60 flex items-center justify-between text-xs font-mono text-green-500/80 group-hover:text-green-400">
          <span>Explore challenges</span>
          <span>--&gt;</span>
        </div>
      </div>
    `;

    card.onclick = () => {
      window.location.href = `/ctf/${ctf.id}`;
    };
    return card;
  }

  function renderAll(list) {
    if (!grid) return;
    grid.innerHTML = "";
    if (list.length === 0) {
      grid.innerHTML = `
        <div class="col-span-full py-16 text-center border border-zinc-900 rounded-2xl bg-zinc-950/50">
          <p class="text-zinc-500 font-mono">NO_CTFS_FOUND</p>
        </div>
      `;
      return;
    }
    list.forEach(item => {
      grid.appendChild(renderCard(item));
    });
  }

  function buildLunrIndex() {
    idx = lunr(function() {
      this.ref('id');
      this.field('name');
      this.field('challenges');
      
      ctfs.forEach(ctf => {
        const challengesText = ctf.challenges.map(c => c.title).join(" ");
        this.add({
          id: ctf.id,
          name: ctf.name,
          challenges: challengesText
        });
      });
    });
  }

  // Initial setup
  buildLunrIndex();
  // Default sort A-Z
  ctfs.sort((a, b) => a.name.localeCompare(b.name));
  renderAll(ctfs);

  // Search Input Handler
  const searchInput = document.getElementById("search");
  if (searchInput) {
    searchInput.addEventListener("input", e => {
      const q = e.target.value.trim();
      if (!q) {
        sortAndRender();
        return;
      }
      
      let results = [];
      try {
        results = idx.search(`*${q}*`);
      } catch (err) {
        results = [];
      }

      let filtered = [];
      if (results.length > 0) {
        const ids = new Set(results.map(r => r.ref));
        filtered = ctfs.filter(c => ids.has(c.id));
      } else {
        // Substring fallback
        const qlow = q.toLowerCase();
        filtered = ctfs.filter(c => {
          if (c.name.toLowerCase().includes(qlow)) return true;
          return c.challenges.some(ch => ch.title.toLowerCase().includes(qlow));
        });
      }
      
      renderAll(filtered);
    });
  }

  // Sort Handler
  const sortSelect = document.getElementById("sort");
  
  function sortAndRender() {
    if (!sortSelect) return;
    const type = sortSelect.value;
    let sorted = [...ctfs];
    
    if (type === "az") {
      sorted.sort((a, b) => a.name.localeCompare(b.name));
    } else if (type === "za") {
      sorted.sort((a, b) => b.name.localeCompare(a.name));
    } else if (type === "writeups") {
      sorted.sort((a, b) => b.writeupCount - a.writeupCount);
    } else if (type === "status") {
      sorted.sort((a, b) => a.status.localeCompare(b.status));
    }
    
    renderAll(sorted);
  }

  if (sortSelect) {
    sortSelect.addEventListener("change", sortAndRender);
  }

  // Keypress '/' shortcut to focus search
  window.addEventListener("keydown", e => {
    if (e.key === "/" && document.activeElement !== searchInput) {
      e.preventDefault();
      searchInput?.focus();
    }
  });
</script>
