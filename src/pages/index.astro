---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import ctfsData from '../data/ctfs.json';
import settingsData from '../data/settings.json';

// Fetch all writeups from content collections
const allWriteups = await getCollection('writeups');

// Process and count writeups for each CTF
const ctfs = ctfsData.ctfs.map(ctf => {
  const ctfWriteups = allWriteups.filter(w => {
    // Resolve CTF ID from frontmatter or the first directory in the slug
    const resolvedCtfId = w.data.ctfId || w.slug.split('/')[0].toLowerCase();
    return resolvedCtfId === ctf.id;
  });

  // Unique categories count
  const categoriesSet = new Set();
  const challengesList: any[] = [];

  ctfWriteups.forEach(w => {
    const rawCategory = w.data.category || w.slug.split('/')[1] || 'Uncategorized';
    // Format category name for consistency
    const category = rawCategory.trim();
    categoriesSet.add(category);
    
    // Resolve Title
    const title = w.data.title || w.slug.split('/').pop()?.replace(/-/g, ' ') || 'Untitled';
    
    // Generate route path
    const categorySlug = category.toLowerCase().replace(/\s+/g, '-');
    const challengeSlug = w.slug.split('/').pop();
    const path = `/ctf/${ctf.id}/${categorySlug}/${challengeSlug}`;
    
    challengesList.push({ title, path });
  });

  return {
    ...ctf,
    writeupCount: ctfWriteups.length,
    categoryCount: categoriesSet.size,
    challenges: challengesList
  };
});

// Format search dataset for the client-side Lunr script
const searchData = ctfs.map(c => ({
  id: c.id,
  name: c.name,
  status: c.status,
  banner: c.banner,
  writeupCount: c.writeupCount,
  categoryCount: c.categoryCount,
  challenges: c.challenges
}));
---

<Layout title="CTF Writeups Archive">
  <div class="space-y-10">
    
    <!-- Hero / Intro -->
    <div class="relative overflow-hidden rounded-3xl border border-white/5 bg-zinc-950/40 p-8 sm:p-12 backdrop-blur-xl">
      <!-- Abstract glow backgrounds -->
      <div class="absolute -right-24 -top-24 w-80 h-80 rounded-full bg-cyan-500/10 blur-[80px] pointer-events-none"></div>
      <div class="absolute -left-24 -bottom-24 w-80 h-80 rounded-full bg-indigo-500/10 blur-[80px] pointer-events-none"></div>
      
      <div class="relative z-10 max-w-3xl space-y-4">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 font-mono">
          <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 animate-pulse"></span>
          SYSTEM_ARCHIVE_ACTIVE
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-white font-outfit leading-tight">
          {settingsData.heroTitle}
        </h1>
        <p class="text-zinc-400 text-base sm:text-lg font-light leading-relaxed">
          {settingsData.heroSubtitle}
        </p>
      </div>
    </div>

    <!-- Controls: Search & Sort -->
    <div class="flex flex-col md:flex-row justify-between items-stretch md:items-center gap-4 bg-zinc-950/20 p-4 border border-white/5 rounded-2xl sticky top-20 z-40 backdrop-blur-xl">
      <div class="relative flex-grow max-w-lg">
        <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-cyan-500 font-mono text-sm">
          &gt;
        </div>
        <input 
          id="search" 
          type="text" 
          placeholder="Search writeups or challenges... (Press '/' to focus)" 
          class="block w-full pl-8 pr-4 py-3 rounded-xl bg-zinc-900/40 text-cyan-300 placeholder-zinc-500 border border-white/5 focus:outline-none focus:border-cyan-500/50 focus:ring-1 focus:ring-cyan-500/30 font-mono text-sm transition-all duration-300"
        />
      </div>
      <div class="flex items-center gap-3">
        <span class="text-xs font-mono text-zinc-500 hidden sm:inline">SORT_BY:</span>
        <select id="sort" class="px-4 py-3 bg-zinc-900/40 text-cyan-400 border border-white/5 rounded-xl focus:outline-none focus:border-cyan-500/50 font-outfit text-sm font-medium cursor-pointer transition-all duration-300">
          <option value="az">A–Z Alphabetical</option>
          <option value="za">Z–A Alphabetical</option>
          <option value="writeups">Writeup Count</option>
          <option value="status">Event Status</option>
        </select>
      </div>
    </div>

    <!-- Grid Container -->
    <div id="ctf-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Generated Dynamically by JS -->
    </div>
  </div>
</Layout>

<!-- Load Lunr.js from CDN -->
<script src="https://unpkg.com/lunr/lunr.js" is:inline></script>

<!-- Combined script block with define:vars to correctly scope searchData -->
<script is:inline define:vars={{ searchData }}>
  let ctfs = searchData || [];
  let idx = null;
  const grid = document.getElementById("ctf-grid");

  function getBannerFallback(ctfId, ctfName) {
    const combos = {
      picoctf: {
        bg: 'from-violet-950 via-indigo-900 to-zinc-950',
        glow: 'bg-indigo-500/10',
        pattern: 'radial-gradient(circle at 1px 1px, rgba(255,255,255,0.08) 1px, transparent 0)',
        size: '16px 16px'
      },
      imaginaryctf: {
        bg: 'from-emerald-950 via-teal-900 to-zinc-950',
        glow: 'bg-cyan-500/10',
        pattern: 'repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(255,255,255,0.04) 10px, rgba(255,255,255,0.04) 12px)',
        size: 'auto'
      }
    };

    const style = combos[ctfId] || {
      bg: 'from-zinc-900 via-zinc-800 to-zinc-950',
      glow: 'bg-white/5',
      pattern: 'linear-gradient(0deg, transparent 24%, rgba(255,255,255,0.02) 25%, rgba(255,255,255,0.02) 26%, transparent 27%, transparent 74%, rgba(255,255,255,0.02) 75%, rgba(255,255,255,0.02) 76%, transparent 77%, transparent)',
      size: '20px 20px'
    };

    return `
      <div class="relative w-full h-44 overflow-hidden bg-gradient-to-tr ${style.bg} border-b border-white/5 flex items-center justify-center">
        <div class="absolute inset-0" style="background-image: ${style.pattern}; background-size: ${style.size};"></div>
        <div class="absolute w-32 h-32 rounded-full ${style.glow} blur-[40px] pointer-events-none"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/90 to-transparent"></div>
        <div class="relative z-10 flex flex-col items-center">
          <div class="text-3xl font-extrabold tracking-widest text-white/20 uppercase select-none font-outfit group-hover:scale-105 group-hover:text-white/45 transition-all duration-500">${ctfName}</div>
        </div>
      </div>
    `;
  }

  window.getBannerFallback = getBannerFallback; // Expose helper globally for image error fallback

  function renderCard(ctf) {
    const card = document.createElement("div");
    card.className = "group relative bg-zinc-950/40 border border-white/5 hover:border-cyan-500/20 hover:shadow-[0_0_30px_rgba(6,182,212,0.05)] rounded-2xl overflow-hidden transition-all duration-300 cursor-pointer flex flex-col h-full backdrop-blur-md";
    
    // Status Badge Color
    const statusColor = ctf.status === 'active' ? 'bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.4)]' : 'bg-zinc-600';
    
    let bannerHtml = '';
    if (ctf.banner && ctf.banner !== 'placeholder.png' && !ctf.banner.includes('placeholder')) {
      bannerHtml = `
        <div class="relative w-full h-44 overflow-hidden bg-zinc-900 border-b border-white/5">
          <img 
            src="/assets/${ctf.banner}" 
            alt="${ctf.name}" 
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 opacity-80"
            onerror="this.parentNode.innerHTML = window.getBannerFallback('${ctf.id}', '${ctf.name}')"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/80 to-transparent"></div>
        </div>
      `;
    } else {
      bannerHtml = getBannerFallback(ctf.id, ctf.name);
    }

    card.innerHTML = `
      ${bannerHtml}
      <!-- Status Badge -->
      <div class="absolute top-4 right-4 flex items-center gap-2 px-2.5 py-1 rounded-full bg-black/60 border border-white/10 text-[10px] font-mono tracking-wider uppercase z-20">
        <span class="w-1.5 h-1.5 rounded-full ${statusColor}"></span>
        <span class="text-zinc-300 font-semibold">${ctf.status}</span>
      </div>
      
      <div class="p-6 flex-grow flex flex-col justify-between space-y-4">
        <div class="space-y-2">
          <h3 class="text-xl font-bold font-outfit text-white group-hover:text-cyan-400 transition-colors duration-300">
            ${ctf.name}
          </h3>
          <div class="flex items-center gap-4 text-xs font-mono text-zinc-500">
            <span>${ctf.categoryCount} Categories</span>
            <span>•</span>
            <span>${ctf.writeupCount} Challenges</span>
          </div>
        </div>
        <div class="pt-4 border-t border-white/5 flex items-center justify-between text-xs font-mono text-cyan-500/80 group-hover:text-cyan-400 transition-colors duration-300">
          <span>Explore challenges</span>
          <span class="transform group-hover:translate-x-1 transition-transform duration-300">--&gt;</span>
        </div>
      </div>
    `;

    card.onclick = () => {
      window.location.href = `/ctf/${ctf.id}`;
    };
    return card;
  }

  function renderAll(list) {
    if (!grid) return;
    grid.innerHTML = "";
    if (list.length === 0) {
      grid.innerHTML = `
        <div class="col-span-full py-16 text-center border border-white/5 rounded-2xl bg-zinc-950/20 backdrop-blur-md">
          <p class="text-zinc-500 font-mono text-sm">NO_CTFS_FOUND</p>
        </div>
      `;
      return;
    }
    list.forEach(item => {
      grid.appendChild(renderCard(item));
    });
  }

  function buildLunrIndex() {
    idx = lunr(function() {
      this.ref('id');
      this.field('name');
      this.field('challenges');
      
      ctfs.forEach(ctf => {
        const challengesText = ctf.challenges.map(c => c.title).join(" ");
        this.add({
          id: ctf.id,
          name: ctf.name,
          challenges: challengesText
        });
      });
    });
  }

  // Initial setup
  buildLunrIndex();
  // Default sort A-Z
  ctfs.sort((a, b) => a.name.localeCompare(b.name));
  renderAll(ctfs);

  // Search Input Handler
  const searchInput = document.getElementById("search");
  if (searchInput) {
    searchInput.addEventListener("input", e => {
      const q = e.target.value.trim();
      if (!q) {
        sortAndRender();
        return;
      }
      
      let results = [];
      try {
        results = idx.search(`*${q}*`);
      } catch (err) {
        results = [];
      }

      let filtered = [];
      if (results.length > 0) {
        const ids = new Set(results.map(r => r.ref));
        filtered = ctfs.filter(c => ids.has(c.id));
      } else {
        // Substring fallback
        const qlow = q.toLowerCase();
        filtered = ctfs.filter(c => {
          if (c.name.toLowerCase().includes(qlow)) return true;
          return c.challenges.some(ch => ch.title.toLowerCase().includes(qlow));
        });
      }
      
      renderAll(filtered);
    });
  }

  // Sort Handler
  const sortSelect = document.getElementById("sort");
  
  function sortAndRender() {
    if (!sortSelect) return;
    const type = sortSelect.value;
    let sorted = [...ctfs];
    
    if (type === "az") {
      sorted.sort((a, b) => a.name.localeCompare(b.name));
    } else if (type === "za") {
      sorted.sort((a, b) => b.name.localeCompare(a.name));
    } else if (type === "writeups") {
      sorted.sort((a, b) => b.writeupCount - a.writeupCount);
    } else if (type === "status") {
      sorted.sort((a, b) => a.status.localeCompare(b.status));
    }
    
    renderAll(sorted);
  }

  if (sortSelect) {
    sortSelect.addEventListener("change", sortAndRender);
  }

  // Keypress '/' shortcut to focus search
  window.addEventListener("keydown", e => {
    if (e.key === "/" && document.activeElement !== searchInput) {
      e.preventDefault();
      searchInput?.focus();
    }
  });
</script>
